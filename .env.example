# Web app (Vite) — copy to .env.local and adjust if the defaults don't fit.
# By default the frontend talks to the backend on the same host it was loaded from,
# port 3001, under /api. Override any of these only if your setup differs.

# Full override (wins over everything below), e.g. http://192.168.1.50:3001/api
# VITE_API_BASE_URL=

# Or override individual parts:
# VITE_API_PROTOCOL=http
# VITE_API_HOST=192.168.1.50
# VITE_API_PORT=3001
# VITE_API_BASE_PATH=/api
